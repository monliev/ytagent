# MySQL Configuration
MYSQL_ROOT_PASSWORD=change_me_to_something_secure_root
MYSQL_USER=ytagent
MYSQL_PASSWORD=change_me_to_something_secure_user
MYSQL_DATABASE=ytagent

# Redis
REDIS_URL=redis://redis:6379/0

# FastAPI
SECRET_KEY=change_me_to_a_long_random_jwt_secret_key
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
SUPERVISOR_TELEGRAM_ID=your_telegram_user_id_here

# Cloudflare AI
CF_AI_URL=https://your-worker.workers.dev/
CF_AI_TOKEN=your_ai_token_or_hermes_api_key_here

# Encryption (Base64 Fernet Key)
# Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_base64_fernet_key_here

# OMV
OMV_MOUNT_PATH=/mnt/omv

# Timezone
TZ=Asia/Jakarta

# Docker Host (uncomment and customize if using user-specific docker socket like macOS Docker Desktop)
# DOCKER_HOST=unix:///Users/your_username/.docker/run/docker.sock
